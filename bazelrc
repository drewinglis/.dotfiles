test --test_output=errors

build --local_resources=memory=HOST_RAM*.5
build --local_resources=cpu=HOST_CPUS-2
build -c dbg --strip=never

# Shared disk cache — content-addressed, so all worktrees / Bazel
# projects on this machine reuse each other's action outputs.
build --disk_cache=~/.cache/bazel-disk-cache
build --experimental_disk_cache_gc_max_size=50G
